# Supabase (required for /api/leads inserts)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Resend (optional — emails skipped if unset)
RESEND_API_KEY=re_xxxxxxxx

# Cloudflare Turnstile (optional — enable together)
# If TURNSTILE_SECRET_KEY is set, the widget must load with NEXT_PUBLIC_TURNSTILE_SITE_KEY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
